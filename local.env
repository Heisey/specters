# ─────────────────────────────────────────────
# LOCAL DEVELOPMENT — FAKE KEYS
# Replace each value with a real key before
# testing auth or payment flows.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ── Clerk (Auth) ─────────────────────────────
# Real keys from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_placeholder_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_placeholder_clerk_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Stripe (Payments) ────────────────────────
# Real keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_placeholder_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_placeholder_stripe_webhook_secret

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_dev

# ── Session / JWT ────────────────────────────
JWT_SECRET=local_dev_jwt_secret_replace_in_production
SESSION_SECRET=local_dev_session_secret_replace_in_production
